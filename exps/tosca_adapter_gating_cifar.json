{
  "prefix": " ",
  "dataset": "cifar224",
  "shuffle": true,
  "memory_size": 0,
  "init_cls": 5,
  "increment": 5,
  "model_name": "adaptive_gating_tosca",
  "backbone_type": "pretrained_vit_b16_224_adapter",
  "pretrained": true,
  "device": ["0"],
  "seed": [1993],

  "mlp_ratio": 16,
  "se_ratio": 16,
  "l1": 0,
  "flow": "tosca",

  "epochs": 20,
  "tuned_epoch": 1,
  "init_lr": 0.01,
  "batch_size": 48,
  "optimizer": "sgd",
  "scheduler": "cosine",
  "lr": 0.025,
  "weight_decay": 0,
  "milestones": [10, 15],
  "use_RP": true,
  "M": 10000,
  "ffn_num": 64,

  "routing_mode": "gate",
  "selection_report_batches": 20,
  "gate_hidden_dim": 0,
  "gate_epochs": 10,
  "gate_lr": 0.001,
  "gate_weight_decay": 0.0,
  "gate_batch_size": 256,
  "gate_synthetic_per_class": 1000,
  "gate_min_variance": 1e-6,
  "gate_normalize_features": true
}

{
    "prefix": " ",
    "dataset": "cifar224",
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "tosca",
    "backbone_type": "vit_base_patch16_224_in21k",
    "pretrained": true,
    "device": ["0"],
    "seed": [1993],
    

{
    "prefix": " ",
    "dataset": "cifar224",
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "tosca",
    "backbone_type": "vit_base_patch16_224_in21k",
    "pretrained": true,
    "device": ["0"],
    "seed": [1993],
    
    "mlp_ratio": 16,
    "se_ratio": 16,
    "l1": 0.0005,
    "flow": "tosca",
    "selection_mode": "entropy",
    "enable_gate": false,
    "gate_num_layers": 1,
    "gate_hidden_dim": 0,
    "gate_samples_per_class": 1000,
    "gate_train_epochs": 20,
    "gate_batch_size": 256,
    "gate_lr": 0.001,
    "gate_weight_decay": 0.0,
    "gate_min_std": 0.0001,

    "epochs": 20,
    "batch_size": 48,
    "optimizer": "sgd",
    "scheduler": "cosine",
    "lr": 0.025,
    "weight_decay": 0,
    "milestones": [10, 15]
}


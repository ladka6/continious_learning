    "se_ratio": 16,
    "l1": 0.0005,
    "flow": "tosca",

    "epochs": 20,
    "batch_size": 48,
    "optimizer": "sgd",
    "scheduler": "cosine",
    "lr": 0.025,
    "weight_decay": 0,
    "milestones": [10, 15]
}

